{
  "name": "taby",
  "version": "1.0.0",
  "description": "Taby Browser \u2014 Fast, Private, Developer-Friendly",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "build": "vite build",
    "electron:dev": "ELECTRON_DEV=1 electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --publish never",
    "dist:mac": "vite build && electron-builder --mac --publish never",
    "dist:linux": "vite build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4",
    "lucide-react": "^0.414.0",
    "framer-motion": "^11.3.0",
    "marked": "^13.0.2",
    "dompurify": "^3.1.6",
    "recharts": "^2.12.7",
    "clsx": "^2.1.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "vite": "^5.3.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.taby.browser",
    "productName": "Taby",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/taby-icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/taby-icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "core7608",
        "repo": "taby_final"
      }
    ],
    "asar": true
  },
  "author": {
    "name": "Taby Browser",
    "email": "taby@taby.app"
  }
}