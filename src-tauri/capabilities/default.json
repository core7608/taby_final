{
  "$schema": "https://schema.tauri.app/schema/capability/2",
  "identifier": "default",
  "description": "Taby Browser default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-create",
    "http:default",
    "shell:allow-open",
    "store:default",
    "notification:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "process:allow-restart",
    "updater:default"
  ]
}
